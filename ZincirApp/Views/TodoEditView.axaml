<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="450"
             xmlns:vm="clr-namespace:ZincirApp.ViewModels"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="ZincirApp.Views.TodoEditView">
    <Grid RowDefinitions="*,Auto" Margin="10">
        <ScrollViewer Grid.Row="0"  >
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <CheckBox Grid.Column="0" Margin="10,0"
                              IsChecked="{Binding (vm:TodoEditViewModel).IsCompleted}"/>
                    <TextBox Grid.Column="1" Watermark="Title" TextWrapping="Wrap"
                             MaxLength="200"
                             Text="{Binding (vm:TodoEditViewModel).Title}"/>
                </Grid>
                <CheckBox Content="Urgent" Margin="10,0"
                          IsChecked="{Binding (vm:TodoEditViewModel).IsUrgent}"/>
                <CheckBox Content="Important" Margin="10,0"
                          IsChecked="{Binding (vm:TodoEditViewModel).IsImportant}"/>
                <CheckBox Content="Pinned" Margin="10,0"
                          IsChecked="{Binding (vm:TodoEditViewModel).IsPinned}"/>
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <DatePicker Grid.Column="0" SelectedDate="{Binding (vm:TodoEditViewModel).TargetDate}" 
                                assists:TextFieldAssist.Label="Target Date"/>
                    <Button Grid.Column="1" Classes="flat" Content="{avalonia:MaterialIconTextExt Kind=Clear}"/>
                </Grid>
                <TextBox Watermark="Description" MinLines="10" AcceptsReturn="True" TextWrapping="Wrap" MaxLength="1000"
                         Text="{Binding (vm:TodoEditViewModel).Description}"/>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="1" Content="Save" 
                Command="{Binding (vm:TodoEditViewModel).SaveCommand}"/>
    </Grid>
    
</UserControl>
