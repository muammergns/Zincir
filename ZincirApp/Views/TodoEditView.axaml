<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="450"
             xmlns:vm="clr-namespace:ZincirApp.ViewModels"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="ZincirApp.Views.TodoEditView">
    <Grid RowDefinitions="*,Auto" Margin="10">
        <ScrollViewer Grid.Row="0"  >
            <StackPanel Spacing="8">
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap">
                    <Run Text="{Binding (vm:TodoEditViewModel).ParentModelTitle}"/>
                </TextBlock>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <CheckBox Grid.Column="0" Margin="10,0"
                              IsChecked="{Binding (vm:TodoEditViewModel).IsCompleted}"/>
                    <TextBox Grid.Column="1" Watermark="Title" TextWrapping="Wrap"
                             MaxLength="200"
                             Text="{Binding (vm:TodoEditViewModel).Title}"/>
                </Grid>
                <CheckBox Content="Urgent" Margin="10,0"
                          IsChecked="{Binding (vm:TodoEditViewModel).IsUrgent}"/>
                <CheckBox Content="Important" Margin="10,0"
                          IsChecked="{Binding (vm:TodoEditViewModel).IsImportant}"/>
                <CheckBox Content="Pinned" Margin="10,0"
                          IsChecked="{Binding (vm:TodoEditViewModel).IsPinned}"/>
                <WrapPanel ItemSpacing="4" LineSpacing="4" >
                    <Button Classes="flat" Name="SelectDateButton">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" >
                                <StackPanel>
                                    <Button Name="CloseDateButton" HorizontalAlignment="Right"
                                            Click="CloseDateButton_OnClick" Padding="8"
                                            Content="{avalonia:MaterialIconExt Kind=Close}"/>
                                    <Calendar 
                                        SelectedDate="{Binding (vm:TodoEditViewModel).TargetDate}"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <Button.Content>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Target Date" FontSize="10" Opacity="0.7" />
                                <TextBlock Text="{Binding (vm:TodoEditViewModel).TargetDateText}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Classes="flat" HorizontalAlignment="Left"
                            Content="{avalonia:MaterialIconTextExt Kind=Clear}"
                            Command="{Binding (vm:TodoEditViewModel).ClearDateCommand}"/>
                </WrapPanel>
                <TextBox Watermark="Description" MinLines="10" AcceptsReturn="True" 
                         TextWrapping="Wrap" MaxLength="1000"
                         Text="{Binding (vm:TodoEditViewModel).Description}"/>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <Button Grid.Column="1"  HorizontalAlignment="Right"
                    Content="{avalonia:MaterialIconTextExt Kind=ContentSave}" 
                    Command="{Binding (vm:TodoEditViewModel).SaveCommand}"/>
            <Button Grid.Column="2" Classes="flat"  HorizontalAlignment="Right"
                    Content="{avalonia:MaterialIconTextExt Kind=Delete}"
                    IsEnabled="{Binding (vm:TodoEditViewModel).IsModelNotNull}"
                    Command="{Binding (vm:TodoEditViewModel).DeleteCommand}"/>
        </Grid>
        
    </Grid>
    
</UserControl>
