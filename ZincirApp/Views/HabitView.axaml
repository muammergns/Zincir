<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
             xmlns:vm="clr-namespace:ZincirApp.ViewModels"
             xmlns:views="clr-namespace:ZincirApp.Views"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="ZincirApp.Views.HabitView">
    
    <Grid x:Name="Root" RowDefinitions="Auto, *,Auto" Margin="4,4,0,4">
        <TextBlock Grid.Row="0" HorizontalAlignment="Center">
            <Run Text="Habit"/>
        </TextBlock>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Grid.RowSpan="2" Margin="0,8">
            <ItemsRepeater ItemsSource="{Binding (vm:HabitViewModel).Store.Items}" Margin="0,0,0,48">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:HabitItemViewModel">
                        <views:HabitItemView/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
        <Button Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="4,4,4,4" Width="40" Height="40" CornerRadius="20"
                Command="{Binding (vm:HabitViewModel).ShowHabitEditViewCommand}">
            <avalonia:MaterialIcon Kind="Plus" Width="28" Height="28"/>
        </Button>
    </Grid>
    
</UserControl>
