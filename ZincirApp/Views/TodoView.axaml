<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:ZincirApp.ViewModels"
             xmlns:views="clr-namespace:ZincirApp.Views"
             xmlns:locale="clr-namespace:ZincirApp.Locale"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:DataType="vm:TodoViewModel"
             x:Class="ZincirApp.Views.TodoView">
    
    <Grid x:Name="Root" RowDefinitions="Auto, *,Auto" Margin="4,4,0,4">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
            <Button Grid.Column="0" Classes="flat" Padding="8" Margin="0,0,8,0" 
                    Command="{Binding (vm:TodoViewModel).ShowMainTodoListCommand}"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button.Content>
                    <avalonia:MaterialIcon Grid.Column="2" Kind="Home"/>
                </Button.Content>
            </Button>
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap">
                <Run Text="{Binding (vm:TodoViewModel).ParentTodoTitle}"/>
            </TextBlock>
            <Button Grid.Column="2" Classes="flat" Padding="8" Margin="0,0,8,0" 
                    Command="{Binding (vm:TodoViewModel).ShowParentTodoListCommand}"
                    
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button.Content>
                    <avalonia:MaterialIcon Grid.Column="2" Kind="PreviousTitle"/>
                </Button.Content>
            </Button>
        </Grid>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="0,8">
            <ItemsRepeater ItemsSource="{Binding (vm:TodoViewModel).Store.Items}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:TodoItemViewModel">
                        <views:TodoItemView/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Margin="4,4,4,4" Width="40" Height="40" CornerRadius="25"
                    Command="{Binding (vm:TodoViewModel).ShowTodoDetailsCommand}">
                <avalonia:MaterialIcon Kind="Plus" Width="28" Height="28"/>
            </Button>
            <WrapPanel Grid.Column="1" ItemSpacing="8" LineSpacing="8">
            
                <CheckBox IsChecked="{Binding (vm:TodoViewModel).IsPinnedList}">
                    <avalonia:MaterialIconText Kind="Pin" Text="Pinned"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding (vm:TodoViewModel).IsImportantList}">
                    <avalonia:MaterialIconText Kind="Warning" Text="Important"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding (vm:TodoViewModel).IsUrgentList}">
                    <avalonia:MaterialIconText Kind="TimerMarker" Text="Urgent"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding (vm:TodoViewModel).IsCompletedList}">
                    <avalonia:MaterialIconText Kind="Tick" Text="Completed"/>
                </CheckBox>
            </WrapPanel>
        </Grid>
        
        
    </Grid>
</UserControl>